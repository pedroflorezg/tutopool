        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{ $json.estudiantes[0].telefono }}\",\n  \"options\": {\n    \"delay\": 1200,\n    \"presence\": \"composing\"\n  },\n  \"messageMessage\": {\n    \"contentText\": \"🎓 *TutoPool - Nueva Solicitud*\\n\\nTienes una solicitud de tutoría para {{ $json.materia_nombre }}. ¿Deseas confirmarla?\",\n    \"footerText\": \"TutoPool v2.0\",\n    \"buttons\": [\n      {\n        \"buttonId\": \"aceptar_{{ $json.sesion_id }}\",\n        \"buttonText\": {\"displayText\": \"Aceptar\"},\n        \"type\": 1\n      },\n      {\n        \"buttonId\": \"rechazar_{{ $json.sesion_id }}\",\n        \"buttonText\": {\"displayText\": \"Rechazar\"},\n        \"type\": 1\n      }\n    ],\n    \"headerType\": 1\n  }\n}",
        "options": {}
