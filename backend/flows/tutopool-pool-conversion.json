      },
      "id": "cf77ec08-9fb4-4310-befa-8035e838316b",
      "name": "Cron Cada Hora",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -656,
        112
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT s.id AS sesion_id, s.materia_id, s.tipo, s.estado, s.fecha_inicio, s.precio_individual, s.precio_grupal, s.min_estudiantes, m.nombre AS materia_nombre, t.nombre AS tutor_nombre, COUNT(i.id) AS total_inscritos, ARRAY_AGG(json_build_object('estudiante_id', i.estudiante_id, 'email', u.email, 'telefono', u.raw_user_meta_data->>'telefono')) AS estudiantes FROM sesiones s JOIN materias m ON s.materia_id = m.id JOIN tutores t ON s.tutor_id = t.id LEFT JOIN inscripciones i ON s.id = i.sesion_id AND i.estado_pago IN ('pendiente', 'pagado') LEFT JOIN auth.users u ON i.estudiante_id = u.id WHERE s.tipo = 'grupal' AND s.estado = 'esperando_cupos' AND s.fecha_inicio BETWEEN NOW() + INTERVAL '23 hours' AND NOW() + INTERVAL '25 hours' GROUP BY s.id, m.nombre, t.nombre HAVING COUNT(i.id) < s.min_estudiantes;",
        "options": {}
      },
      "id": "14ba266c-cbf7-4639-a8e4-0327d317dd9f",
      "name": "Buscar Sesiones Bajo Cupo",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -448,
        112
      ],
      "credentials": {
        "postgres": {
          "id": "BjOM9Q04vHkpnGCV",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
