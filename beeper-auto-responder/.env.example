# ──────────────────────────────────────────────
# Beeper Auto-Responder Configuration
# ──────────────────────────────────────────────

# ── Beeper / Matrix credentials ──────────────
# Your Beeper homeserver (default: https://matrix.beeper.com)
MATRIX_HOMESERVER_URL=https://matrix.beeper.com

# Your Beeper username (Matrix user ID, e.g. @yourname:beeper.com)
MATRIX_USER_ID=@yourname:beeper.com

# Your Beeper access token (get from Beeper Desktop: Settings → Help → Access Token)
MATRIX_ACCESS_TOKEN=your_access_token_here

# ── Claude AI ────────────────────────────────
# Anthropic API key for Claude-powered auto-responses
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Auto-Responder Settings ──────────────────
# Enable auto-responding to incoming messages (true/false)
AUTO_RESPOND_ENABLED=true

# Maximum number of recent messages to include as context for Claude
CONTEXT_MESSAGE_COUNT=20

# ── Re-Engagement Settings ───────────────────
# Enable periodic re-engagement messages (true/false)
REENGAGEMENT_ENABLED=true

# Cron schedule for checking re-engagement (default: every day at 9am)
REENGAGEMENT_CRON=0 9 * * *

# Default days of inactivity before sending a re-engagement message
DEFAULT_INACTIVITY_DAYS=7

# ── Logging ──────────────────────────────────
# Log level: error, warn, info, debug
LOG_LEVEL=info
