# ─── n8n cloud deploy ───────────────────────────────────────────
N8N_CLOUD_URL=https://tu-instancia.n8n.cloud
N8N_CLOUD_API_KEY=

# ─── Evolution API (WhatsApp) ────────────────────────────────────
EVOLUTION_API_KEY=

# ─── Google OAuth (para supabase/config.toml local) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# ─── Microsoft Azure OAuth ───────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_SECRET=
